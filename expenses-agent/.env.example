DEEPSEEK_API_KEY=sk-...
EXPENSES_API_URL=http://localhost:8000/api/v1 # Feel free to keep it as is!
OLLAMA_URL= # Set this to your Ollama base URL to use a local model instead of DeepSeek (e.g. http://localhost:11434)
LANGSMITH_API_KEY=lsv2... # Optional — get from https://smith.langchain.com/settings
LANGSMITH_TRACING=true # Optional — set to true to enable passive tracing to LangSmith
LANGSMITH_PROJECT=momo-expenses # Optional — organizes traces by project in LangSmith
